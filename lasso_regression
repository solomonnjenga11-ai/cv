import argparse
import sys
from typing import List, Optional

import yfinance as yf
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt


def download_data(ticker: str, start: str, end: str) -> pd.DataFrame:
    data = yf.download(ticker, start=start, end=end, progress=False)
    if data.empty:
        raise ValueError(f"No data returned for {ticker}. Check the ticker or date range.")
    data = data.rename(columns={"Adj Close": "AdjClose"})
    data["Returns"] = data["AdjClose"].pct_change()
    return data


def compute_signals(
    df: pd.DataFrame,
    window: int = 20,
    upper_z: float = 1.0,
    lower_z: float = -1.0
) -> pd.DataFrame:
    df = df.copy()
    rolling_mean = df["AdjClose"].rolling(window).mean()
    rolling_std = df["AdjClose"].rolling(window).std()

    df["RollingMean"] = rolling_mean
    df["RollingStd"] = rolling_std
    df["ZScore"] = (df["AdjClose"] - rolling_mean) / rolling_std

    # Signal: 1 = long, -1 = short, 0 = flat
    df["Signal"] = np.where(df["ZScore"] > upper_z, -1,
                     np.where(df["ZScore"] < lower_z, 1, 0))
    return df


def backtest(
    df: pd.DataFrame,
    transaction_cost_bps: float = 0.0
) -> pd.DataFrame:
    df = df.copy()

    # Shift signal to avoid look-ahead bias
    df["Position"] = df["Signal"].shift(1).fillna(0)

    # Transaction costs applied on position changes
    pos_change = df["Position"].diff().fillna(0).abs()
    # Convert bps to decimal
    tc = transaction_cost_bps / 10000.0
    df["TransactionCost"] = pos_change * tc

    df["StrategyReturnsGross"] = df["Position"] * df["Returns"]
    df["StrategyReturns"] = df["StrategyReturnsGross"] - df["TransactionCost"]

    df["CumulativeMarket"] = (1 + df["Returns"].fillna(0)).cumprod()
    df["CumulativeStrategy"] = (1 + df["StrategyReturns"].fillna(0)).cumprod()
    return df


def performance_metrics(df: pd.DataFrame) -> dict:
    strat = df["StrategyReturns"].dropna()
    market = df["Returns"].dropna()

    def annualize_ret(series: pd.Series, periods_per_year: int = 252) -> float:
        mean = series.mean()
        return mean * periods_per_year

    def annualize_vol(series: pd.Series, periods_per_year: int = 252) -> float:
        return series.std() * np.sqrt(periods_per_year)

    def sharpe(series: pd.Series, rf: float = 0.0, periods_per_year: int = 252) -> float:
        ann_ret = annualize_ret(series, periods_per_year)
        ann_vol = annualize_vol(series, periods_per_year)
        return (ann_ret - rf) / ann_vol if ann_vol != 0 else np.nan

    def max_drawdown(cum: pd.Series) -> float:
        roll_max = cum.cummax()
        drawdown = (cum / roll_max) - 1.0
        return drawdown.min()

    metrics = {
        "strategy_annual_return": annualize_ret(strat),
        "strategy_annual_vol": annualize_vol(strat),
        "strategy_sharpe": sharpe(strat),
        "strategy_max_drawdown": max_drawdown(df["CumulativeStrategy"].dropna()),
        "market_annual_return": annualize_ret(market),
        "market_annual_vol": annualize_vol(market),
        "market_sharpe": sharpe(market),
        "market_max_drawdown": max_drawdown(df["CumulativeMarket"].dropna()),
    }
    return metrics


def plot_results(df: pd.DataFrame, ticker: str, window: int, upper_z: float, lower_z: float) -> None:
    plt.figure(figsize=(12, 6))
    plt.plot(df.index, df["CumulativeMarket"], label="Market Buy & Hold")
    plt.plot(df.index, df["CumulativeStrategy"], label="Mean Reversion Strategy")
    plt.title(f"Mean Reversion Strategy vs Market ({ticker}) | window={window}, z> {upper_z}, z< {lower_z}")
    plt.xlabel("Date")
    plt.ylabel("Cumulative Returns")
    plt.legend()
    plt.tight_layout()
    plt.show()


def run_single(
    ticker: str,
    start: str,
    end: str,
    window: int,
    upper_z: float,
    lower_z: float,
    transaction_cost_bps: float,
    plot: bool
) -> dict:
    df = download_data(ticker, start, end)
    df = compute_signals(df, window=window, upper_z=upper_z, lower_z=lower_z)
    df = backtest(df, transaction_cost_bps=transaction_cost_bps)
    metrics = performance_metrics(df)

    if plot:
        plot_results(df, ticker, window, upper_z, lower_z)

    return metrics


def run_multi(
    tickers: List[str],
    start: str,
    end: str,
    window: int,
    upper_z: float,
    lower_z: float,
    transaction_cost_bps: float,
    plot: bool
) -> pd.DataFrame:
    rows = []
    for t in tickers:
        try:
            m = run_single(
                ticker=t,
                start=start,
                end=end,
                window=window,
                upper_z=upper_z,
                lower_z=lower_z,
                transaction_cost_bps=transaction_cost_bps,
                plot=plot
            )
            m["ticker"] = t
            rows.append(m)
        except Exception as e:
            print(f"Skipping {t}: {e}", file=sys.stderr)

    return pd.DataFrame(rows).set_index("ticker")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Mean Reversion Trading Strategy Backtest"
    )
    parser.add_argument("--tickers", type=str, default="AAPL",
                        help="Comma-separated list of tickers (e.g., AAPL,MSFT,GOOG)")
    parser.add_argument("--start", type=str, default="2020-01-01",
                        help="Start date (YYYY-MM-DD)")
    parser.add_argument("--end", type=str, default="2025-01-01",
                        help="End date (YYYY-MM-DD)")
    parser.add_argument("--window", type=int, default=20,
                        help="Rolling window length for mean and std")
    parser.add_argument("--upper_z", type=float, default=1.0,
                        help="Z-score threshold above which we short")
    parser.add_argument("--lower_z", type=float, default=-1.0,
                        help="Z-score threshold below which we go long")
    parser.add_argument("--tc_bps", type=float, default=0.0,
                        help="Transaction cost in basis points per position change")
    parser.add_argument("--plot", action="store_true",
                        help="Plot cumulative returns")
    return parser.parse_args()


def main():
    args = parse_args()
    tickers = [t.strip() for t in args.tickers.split(",") if t.strip()]
    if len(tickers) == 1:
        metrics = run_single(
            ticker=tickers[0],
            start=args.start,
            end=args.end,
            window=args.window,
            upper_z=args.upper_z,
            lower_z=args.lower_z,
            transaction_cost_bps=args.tc_bps,
            plot=args.plot
        )
        print("Results:")
        for k, v in metrics.items():
            print(f"{k}: {v:.6f}" if isinstance(v, (int, float, np.floating)) else f"{k}: {v}")
    else:
        df = run_multi(
            tickers=tickers,
            start=args.start,
            end=args.end,
            window=args.window,
            upper_z=args.upper_z,
            lower_z=args.lower_z,
            transaction_cost_bps=args.tc_bps,
            plot=args.plot
        )
        print(df)


if __name__ == "__main__":
    main()
